local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

Players.PlayerAdded:Connect(function(player)
    if player ~= LocalPlayer then
        -- Check if the joining player is your friend
        local success, isFriend = pcall(function()
            return LocalPlayer:IsFriendsWith(player.UserId)
        end)
        
        if success and isFriend then
            -- Display the notification using their Display Name and Username
            Rayfield:Notify({
                Title = "Ur friendo has joined u",
                Content = player.DisplayName .. " (@" .. player.Name .. ") has joined the game.",
                Duration = 6.5, -- Duration in seconds
                Image = 4483362458 -- You can also use a string like "rewind" for Lucide icons
            })
        end

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Rayfield = loadstring(game:HttpGet('https://githubusercontent.com'))()

Players.PlayerRemoving:Connect(function(player)
    -- Ignore the LocalPlayer leaving
    if player == LocalPlayer then return end

    -- Check if the player is your friend
    local success, isFriend = pcall(function()
        return LocalPlayer:IsFriendsWith(player.UserId)
    end)

    -- Display Rayfield notification with Display Name
    if success and isFriend then
        Rayfield:Notify({
            Title = " Ur friendo has left",
            Content = player.DisplayName .. " has left the game.",
            Duration = 6.5,
            Image = 4483362458 -- You can change this to a Lucide icon string if you prefer
        })
    end
end)
